DB_PATH=/data/database.db
SECRET_KEY=NemesisUltraSecret2026

ADMIN_USER=admin
ADMIN_PASSWORD=1234

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ENABLE_OPENAI=true
OPENAI_MONTHLY_LIMIT=20

# V32.2 FOOTBALL SEASON AUTO ENGINE
# No necesitas API-Football. The Odds API es la fuente principal.
ENABLE_API_FOOTBALL=false
API_FOOTBALL_KEY=

ENABLE_ODDS_API=true
ODDS_PROVIDER=theoddsapi
ODDS_API_KEY=tu_clave_the_odds_api
THE_ODDS_API_KEY=tu_clave_the_odds_api

# Mercado europeo/reino unido y mercados principales.
ODDS_REGIONS=eu,uk
ODDS_MARKETS=h2h,totals,spreads

# Si lo dejas vacío, la app usa la lista completa fútbol+torneos y filtra automáticamente los deportes activos.
# Incluye Mundial, Champions, Eurocopa, Copa América y ligas cuando empiecen.
ODDS_SPORT_KEYS=soccer_fifa_world_cup,soccer_uefa_champs_league,soccer_uefa_europa_league,soccer_uefa_europa_conference_league,soccer_uefa_european_championship,soccer_conmebol_copa_america,soccer_spain_la_liga,soccer_epl,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_portugal_primeira_liga,soccer_netherlands_eredivisie,soccer_spain_segunda_division,soccer_efl_champ,soccer_usa_mls,soccer_mexico_ligamx,soccer_brazil_campeonato,soccer_argentina_primera_division

FOOTBALL_FIRST=true
SHOW_BASKETBALL_DEFAULT=false
AUTO_FILTER_ACTIVE_SPORTS=true
ODDS_SPORTS_CACHE_MINUTES=360
MAX_EVENTS_PER_SPORT=20
ODDS_MONTHLY_CREDIT_LIMIT=18000
ODDS_CACHE_MINUTES=30
API_CACHE_MINUTES=10
LIVE_AUTO_REFRESH=true

# Opcional: TheSportsDB solo si tienes clave. Puedes dejarlo desactivado.
ENABLE_LIVE_API=false
LIVE_PROVIDER=thesportsdb
THESPORTSDB_KEY=
THESPORTSDB_SPORT=Soccer
LIVE_DAILY_REQUEST_LIMIT=80
LIVE_CACHE_MINUTES=3

# Motor automático de valor SHARK
SHARK_ENGINE_MIN_SCORE=68
SHARK_ENGINE_PREMIUM_SCORE=78
SHARK_ENGINE_MAX_PICKS=18
SHARK_ENGINE_CACHE_TTL=900
SHARK_ENGINE_AUTO_SAVE=false
SHARK_ENGINE_SPORTS=soccer_fifa_world_cup,soccer_uefa_champs_league,soccer_spain_la_liga,soccer_epl,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_portugal_primeira_liga

APP_VERSION=V32_2_FOOTBALL_SEASON_AUTO_ENGINE
CACHE_REFRESH_MINUTES=10

# V35.0 — Clasificaciones tipo Flashscore y escudos reales
# The Odds API no trae tablas ni escudos oficiales. Esta clave activa clasificaciones reales.
ENABLE_STANDINGS=true
FOOTBALL_DATA_KEY=
STANDINGS_CACHE_MINUTES=720

# V36.0 PROFESSIONAL PLATFORM LAYER
# PWA ya viene activa por manifest/service-worker.
# Alertas opcionales: no rompen la app si están vacías.
ENABLE_PRO_ALERTS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# V42.0 — Alertas Telegram reales
# Crea un bot con BotFather, mete el bot en tu grupo/canal y pon aquí los datos.
ENABLE_PRO_ALERTS=true
TELEGRAM_BOT_TOKEN=123456:ABCDEF_TU_TOKEN
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_ALERT_MIN_SCORE=75
TELEGRAM_ALERT_ONLY_PREMIUM=false
TELEGRAM_ALERT_NEW_PICKS=true
TELEGRAM_ALERT_RESULTS=true
# Discord opcional
DISCORD_WEBHOOK_URL=

# V43.0 — Telegram por membresía + alertas automáticas
# Puedes usar un solo canal con TELEGRAM_CHAT_ID o separar por planes.
TELEGRAM_BOT_USERNAME=nemesis_shark_pro_bot
TELEGRAM_GROUP_URL=https://t.me/tu_canal_general
TELEGRAM_FREE_CHAT_ID=
TELEGRAM_PRO_CHAT_ID=
TELEGRAM_ELITE_CHAT_ID=
TELEGRAM_FREE_GROUP_URL=
TELEGRAM_PRO_GROUP_URL=
TELEGRAM_ELITE_GROUP_URL=
TELEGRAM_AUTO_ALERT_ENGINE=true
TELEGRAM_AUTO_ALERT_MAX_PER_RUN=3

# V46.0 — Telegram full automation
# Enviar señales automáticamente al crear picks desde admin y al generar picks SHARK
TELEGRAM_SEND_ON_ADMIN_CREATE=true
TELEGRAM_SEND_TO_CONNECTED_USERS=true
TELEGRAM_SEND_TO_PLAN_CHANNELS=true
# Chat opcional solo para pruebas de admin si aún no separas canales
TELEGRAM_TEST_CHAT_ID=

# Escudos locales opcionales sin otra API.
# Sube archivos a static/team_logos con nombre normalizado: real_madrid.png, barcelona.svg, manchester_city.webp
LOCAL_TEAM_LOGOS_DIR=static/team_logos

# V44.0 Live Results Pro Experience
AUTO_RESULT_SETTLEMENT=true
LIVE_PRO_MODE=true

# V47.0 — SHARK Quality Control
# Evita spam, picks repetidos y señales de baja calidad en Telegram.
SHARK_MIN_SCORE=70
TELEGRAM_QUIET_HOURS=true
TELEGRAM_QUIET_START=01
TELEGRAM_QUIET_END=08
MIN_ALLOWED_ODDS=1.40
MAX_ALLOWED_ODDS=4.50
MAX_ALERTS_PER_HOUR=6
TELEGRAM_BLOCK_DUPLICATE_MATCHES=true
TELEGRAM_QUALITY_MODE=strict

# V50.0 — Push Notifications / avisos móviles de app
# Para generar claves VAPID puedes usar: python -m pywebpush --generate-vapid-keys
ENABLE_PUSH_NOTIFICATIONS=true
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:soporte@nemesis-shark.local
PUSH_SEND_ON_NEW_PICK=true
PUSH_SEND_ON_RESULTS=true
PUSH_MIN_SCORE=70
PUSH_MAX_DAILY_PER_USER=8


# V51 Performance Stability Engine
PERFORMANCE_SAFE_MODE=true
PUBLIC_LIVE_REFRESH_COOLDOWN_SECONDS=600
ADMIN_REFRESH_COOLDOWN_SECONDS=180
MAX_SPORTS_PER_REFRESH=6
HTTP_TIMEOUT_SECONDS=7
TELEGRAM_AUTO_SEND_DURING_REFRESH=false
BACKGROUND_JOBS_ENABLED=false

# V54.0 Performance/Stability final
STABILITY_HARD_MODE=true
DB_ENABLE_WAL=true
DB_BUSY_TIMEOUT_MS=8000
API_REFRESH_LOCK_SECONDS=240
PRUNE_LOGS_ON_STARTUP=true
MAX_ALERT_LOG_ROWS=800
MAX_API_USAGE_LOG_ROWS=1200
CLIENT_API_MAX_ROWS=24
LIVE_SNAPSHOT_LIMIT=8
PUBLIC_ENDPOINT_TIMEOUT_GUARD=true
PERFORMANCE_SAFE_MODE=true
PUBLIC_LIVE_REFRESH_COOLDOWN_SECONDS=900
ADMIN_REFRESH_COOLDOWN_SECONDS=240
MAX_SPORTS_PER_REFRESH=4
HTTP_TIMEOUT_SECONDS=6
TELEGRAM_AUTO_SEND_DURING_REFRESH=false
BACKGROUND_JOBS_ENABLED=false


