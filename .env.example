# NeMeSiS SHARK PRO - .env.example SEGURO
# Copia este archivo como .env en local o configura estas variables en Render.
# NO pongas claves reales en GitHub.

SECRET_KEY=
FLASK_ENV=production
DEBUG=false

ADMIN_USER=
ADMIN_PASSWORD=

DB_PATH=data/database.db
SQLITE_DB_PATH=nemesis.db
DATABASE_URL=

ENABLE_ODDS_API=true
ODDS_PROVIDER=theoddsapi
ODDS_API_KEY=
THE_ODDS_API_KEY=
ODDS_REGIONS=eu
ODDS_MARKETS=h2h,spreads,totals
ODDS_TIMEZONE=Europe/Madrid

ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MONTHLY_LIMIT=

ENABLE_PRO_ALERTS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_TO_PLAN_CHANNELS=false
TELEGRAM_SEND_ON_ADMIN_CREATE=true
TELEGRAM_RETRY_ON_FAIL=true
TELEGRAM_MAX_RETRIES=3
TELEGRAM_FORCE_TEST_ALERTS=false

ENABLE_PUSH_NOTIFICATIONS=true
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:soporte@nemesissharkpro.com

STABILITY_HARD_MODE=true
PERFORMANCE_SAFE_MODE=true
PUBLIC_LIVE_REFRESH_COOLDOWN_SECONDS=900
ADMIN_REFRESH_COOLDOWN_SECONDS=240
MAX_SPORTS_PER_REFRESH=4
HTTP_TIMEOUT_SECONDS=6
BACKGROUND_JOBS_ENABLED=false
DB_ENABLE_WAL=true

V82_TIMEZONE_FIX_ENABLED=true
APP_TIMEZONE=Europe/Madrid
DISPLAY_TIMEZONE=Europe/Madrid
BLOCK_FAKE_FUTURE_YEARS=true
MAX_FUTURE_DAYS=45
HIDE_INVALID_MATCH_DATES=true

V81_STRIPE_STILL_DISABLED=true

# V84 PREMIUM ENGAGEMENT EXPERIENCE
V84_PREMIUM_ENGAGEMENT_ENABLED=true
V84_XP_SYSTEM_ENABLED=true
V84_BADGES_ENABLED=true
V84_UX_MISSIONS_ENABLED=true
V84_MICROANIMATIONS_ENABLED=true

# V85 MATCH CARDS PRO
V85_MATCH_CARDS_PRO_ENABLED=true
V85_VISIBLE_DATE_ENABLED=true
V85_CLEAN_TIME_LABELS=true
V85_PRO_AI_REASONS=true
V85_MATCH_CARD_POLISH=true

# V86 LIVE DATA REAL ENGINE
V86_LIVE_DATA_REAL_ENGINE_ENABLED=true
V86_HIDE_INVALID_MATCHES=true
V86_MIN_DATA_SCORE=55
V86_MAX_FUTURE_DAYS=30
V86_MAX_PAST_HOURS=12
V86_BLOCK_DEMO_TEAMS=true
V86_CLEAN_TIME_LABELS=true

# V87 SHARK AI PICK QUALITY
V87_SHARK_AI_PICK_QUALITY_ENABLED=true
V87_MIN_PUBLIC_PICK_SCORE=68
V87_MIN_ELITE_PICK_SCORE=82
V87_HIDE_REJECTED_PICKS=true
V87_HUMAN_REASONS_ENABLED=true
V87_RISK_ENGINE_ENABLED=true
