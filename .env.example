# NeMeSiS SHARK PRO - .env.example SEGURO
# Copia este archivo como .env en local o configura estas variables en Render.
# NO pongas claves reales en GitHub.

SECRET_KEY=
FLASK_ENV=production
DEBUG=false

ADMIN_USER=
ADMIN_PASSWORD=

DB_PATH=data/database.db
SQLITE_DB_PATH=nemesis.db
DATABASE_URL=

ENABLE_ODDS_API=true
ODDS_PROVIDER=theoddsapi
ODDS_API_KEY=
THE_ODDS_API_KEY=
ODDS_REGIONS=eu
ODDS_MARKETS=h2h,spreads,totals
ODDS_TIMEZONE=Europe/Madrid

ENABLE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MONTHLY_LIMIT=

ENABLE_PRO_ALERTS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_TO_PLAN_CHANNELS=false
TELEGRAM_SEND_ON_ADMIN_CREATE=true
TELEGRAM_RETRY_ON_FAIL=true
TELEGRAM_MAX_RETRIES=3
TELEGRAM_FORCE_TEST_ALERTS=false

ENABLE_PUSH_NOTIFICATIONS=true
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:soporte@nemesissharkpro.com

STABILITY_HARD_MODE=true
PERFORMANCE_SAFE_MODE=true
PUBLIC_LIVE_REFRESH_COOLDOWN_SECONDS=900
ADMIN_REFRESH_COOLDOWN_SECONDS=240
MAX_SPORTS_PER_REFRESH=4
HTTP_TIMEOUT_SECONDS=6
BACKGROUND_JOBS_ENABLED=false
DB_ENABLE_WAL=true

V82_TIMEZONE_FIX_ENABLED=true
APP_TIMEZONE=Europe/Madrid
DISPLAY_TIMEZONE=Europe/Madrid
BLOCK_FAKE_FUTURE_YEARS=true
MAX_FUTURE_DAYS=45
HIDE_INVALID_MATCH_DATES=true

V81_STRIPE_STILL_DISABLED=true

# V84 PREMIUM ENGAGEMENT EXPERIENCE
V84_PREMIUM_ENGAGEMENT_ENABLED=true
V84_XP_SYSTEM_ENABLED=true
V84_BADGES_ENABLED=true
V84_UX_MISSIONS_ENABLED=true
V84_MICROANIMATIONS_ENABLED=true

# V85 MATCH CARDS PRO
V85_MATCH_CARDS_PRO_ENABLED=true
V85_VISIBLE_DATE_ENABLED=true
V85_CLEAN_TIME_LABELS=true
V85_PRO_AI_REASONS=true
V85_MATCH_CARD_POLISH=true

# V86 LIVE DATA REAL ENGINE
V86_LIVE_DATA_REAL_ENGINE_ENABLED=true
V86_HIDE_INVALID_MATCHES=true
V86_MIN_DATA_SCORE=55
V86_MAX_FUTURE_DAYS=30
V86_MAX_PAST_HOURS=12
V86_BLOCK_DEMO_TEAMS=true
V86_CLEAN_TIME_LABELS=true

# V87 SHARK AI PICK QUALITY
V87_SHARK_AI_PICK_QUALITY_ENABLED=true
V87_MIN_PUBLIC_PICK_SCORE=68
V87_MIN_ELITE_PICK_SCORE=82
V87_HIDE_REJECTED_PICKS=true
V87_HUMAN_REASONS_ENABLED=true
V87_RISK_ENGINE_ENABLED=true

# V88 ADMIN PRODUCTION CENTER
V88_ADMIN_PRODUCTION_CENTER_ENABLED=true
V88_HEALTH_CHECK_ENABLED=true
V88_PRODUCTION_SCORE_ENABLED=true
V88_ENV_AUDIT_ENABLED=true

# V89 REAL MATCH ENGINE
V89_REAL_MATCH_ENGINE_ENABLED=true
V89_STRICT_REAL_ONLY=true
V89_NO_DEMO_FALLBACK=true
V89_HIDE_FAKE_MATCHES=true
V89_MAX_FUTURE_DAYS=7
V89_MAX_PAST_HOURS=4
V89_MIN_REAL_SCORE=65
V89_REAL_MATCH_CACHE_SECONDS=300
V89_ODDS_SPORTS=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_uefa_champs_league

# V89.1 REAL MATCH FULL INTEGRATION
V891_PUBLIC_ROUTES_USE_REAL_ENGINE=true
V891_DISABLE_LEGACY_PUBLIC_PICKS=true
V891_PURGE_FAKE_LEGACY_PICKS=true
V89_STRICT_REAL_ONLY=true
V89_NO_DEMO_FALLBACK=true
V89_HIDE_FAKE_MATCHES=true

V90_HARD_KILL_LEGACY_CARDS=true
V89_STRICT_REAL_ONLY=true
V89_NO_DEMO_FALLBACK=true
V89_HIDE_FAKE_MATCHES=true

# V91 REAL CORE ENGINE
V91_REAL_CORE_ENGINE_ENABLED=true
V91_SINGLE_SOURCE_OF_TRUTH=true
V91_DISABLE_LEGACY_PUBLIC_ROUTES=true
V91_PURGE_LEGACY_ON_BOOT=true
V91_CORE_CACHE_SECONDS=300
V91_MAX_FUTURE_DAYS=7
V91_MAX_PAST_HOURS=4
V91_MIN_REAL_SCORE=70
V91_CORE_SPORTS=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_portugal_primeira_liga,soccer_uefa_champs_league
V89_STRICT_REAL_ONLY=true
V89_NO_DEMO_FALLBACK=true
V89_HIDE_FAKE_MATCHES=true

# V92 CLIENT PANEL RECOVERY PRO
V92_CLIENT_PANEL_RECOVERY_ENABLED=true
V92_CLIENT_PANEL_REAL_CORE_ONLY=true
V92_CLIENT_PANEL_NO_DEMO=true
V92_CLIENT_PANEL_SAFE_EMPTY=true

# V93 CLIENT PRO REAL UX
V93_CLIENT_PRO_REAL_UX_ENABLED=true
V93_REAL_CORE_ONLY=true
V93_NO_FAKE_MATCHES=true

# V96 no añade variables obligatorias.
# Usa Real Core existente: THE_ODDS_API_KEY / ODDS_API_KEY.

# V97 Admin PRO SaaS Center
# Necesario para Health Score de producción
SECRET_KEY=change-me
DATABASE_PATH=instance/nemesis.db
# Telegram real ya preparado desde V95
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Real Core odds provider
ODDS_API_KEY=
THE_ODDS_API_KEY=
ENV=production

# V166 Stripe/Billing real foundation
# Dejar vacío hasta configurar pagos reales. La app funciona en modo seguro sin estas claves.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=
PUBLIC_BASE_URL=

# V172 Telegram Membership Delivery PRO
# Admin recibe TODO en modo máximo. Clientes reciben según membresía.
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_FREE_CHAT_ID=
TELEGRAM_PRO_CHAT_ID=
TELEGRAM_ELITE_CHAT_ID=
TELEGRAM_CRON_SECRET=

# V173 Telegram Auto Delivery REAL
TELEGRAM_AUTO_DELIVERY_ENABLED=1
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_FREE_CHAT_ID=
TELEGRAM_PRO_CHAT_ID=
TELEGRAM_ELITE_CHAT_ID=
TELEGRAM_CRON_SECRET=change_me_secure
TELEGRAM_ANTI_REPEAT_HOURS=18
TELEGRAM_ADMIN_ALWAYS=1
TELEGRAM_CLIENTS_ENABLED=1
TELEGRAM_PLAN_CHANNELS_ENABLED=1

# V174 Telegram admin private delivery + channel delivery
# Chat privado del dueño/admin. NO lleva -100.
TELEGRAM_ADMIN_CHAT_ID=793831597
# Canal o grupo público/privado donde publica el bot. Normalmente empieza por -100.
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
